{
  "expo": {
    "name": "مجلة السياحة العربية",
    "slug": "AlsyahaAlarabiya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-1024.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alsyahaalarabia2.app"
    },
    "android": {
      "package": "com.alsyahaalarabia2.app",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "navigationBar": {
        "visible": "sticky-immersive",
        "backgroundColor": "#000000"
      },
      "statusBar": {
        "translucent": true,
        "backgroundColor": "transparent"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/app-icon-1024.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "407b7208-044c-424a-96d9-25c154483a77"
      }
    },
    "owner": "salimsayed"
  }
}
